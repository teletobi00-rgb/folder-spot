<ui:FluentWindow x:Class="Explorer.App.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:app="clr-namespace:Explorer.App"
                 xmlns:viewmodels="clr-namespace:Explorer.App.ViewModels"
                 xmlns:views="clr-namespace:Explorer.App.Views"
                 mc:Ignorable="d"
                 d:DataContext="{d:DesignInstance Type=viewmodels:MainWindowViewModel}"
                 Title="Folder Spot"
                 Icon="pack://application:,,,/Assets/app.ico"
                 Width="1280"
                 Height="760"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 FontFamily="{StaticResource AppFontFamily}"
                 FontSize="13"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round">
    <ui:FluentWindow.Resources>
        <!-- 하단 단축키 기능 바 버튼 (TC 스타일) — DynamicResource로 다크/라이트 테마에 적응 -->
        <Style x:Key="FnKeyButton" TargetType="Button">
            <Setter Property="Margin" Value="3,1" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Padding="{TemplateBinding Padding}"
                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 즐겨찾기 호버 시 나타나는 작은 버튼(위/아래/제거) -->
        <Style x:Key="FavHoverButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="3,0" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Padding="{TemplateBinding Padding}"
                                Background="Transparent"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>
    <!-- 키 바인딩은 중앙 키맵(keymap.json 오버라이드 가능)에서 코드비하인드가 구성한다 -->
    <Grid>
        <Grid.RowDefinitions>
            <!-- 0 제목 -->
            <RowDefinition Height="Auto" />
            <!-- 1 툴바 -->
            <RowDefinition Height="Auto" />
            <!-- 2 빠른 실행 바 -->
            <RowDefinition Height="Auto" />
            <!-- 3 본문 -->
            <RowDefinition Height="*" />
            <!-- 4 작업 큐 -->
            <RowDefinition Height="Auto" />
            <!-- 5 단축키 바 -->
            <RowDefinition Height="Auto" />
            <!-- 6 상태바 -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Folder Spot">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Width="18"
                              Height="18"
                              Source="pack://application:,,,/Assets/app.ico" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- 툴바: 네비게이션 + 주소창 + 분할/테마 -->
        <Grid Grid.Row="1" Margin="8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <ui:Button Margin="0,0,4,0"
                           Command="{Binding Workspace.ActiveFileList.GoBackCommand}"
                           ToolTip="뒤로 (Alt+←)">
                    <ui:SymbolIcon Symbol="ArrowLeft24" />
                </ui:Button>
                <ui:Button Margin="0,0,4,0"
                           Command="{Binding Workspace.ActiveFileList.GoForwardCommand}"
                           ToolTip="앞으로 (Alt+→)">
                    <ui:SymbolIcon Symbol="ArrowRight24" />
                </ui:Button>
                <ui:Button Margin="0,0,4,0"
                           Command="{Binding Workspace.ActiveFileList.GoUpCommand}"
                           ToolTip="위로 (Alt+↑)">
                    <ui:SymbolIcon Symbol="ArrowUp24" />
                </ui:Button>
                <ui:Button Margin="0,0,8,0"
                           Command="{Binding Workspace.ActiveFileList.RefreshCommand}"
                           ToolTip="새로 고침 (Ctrl+R)">
                    <ui:SymbolIcon Symbol="ArrowClockwise24" />
                </ui:Button>
            </StackPanel>

            <ui:TextBox Grid.Column="1"
                        VerticalAlignment="Center"
                        Text="{Binding AddressBar.Text, UpdateSourceTrigger=PropertyChanged}"
                        ToolTip="{Binding AddressBar.ErrorText}">
                <ui:TextBox.InputBindings>
                    <KeyBinding Key="Return" Command="{Binding AddressBar.SubmitCommand}" />
                </ui:TextBox.InputBindings>
            </ui:TextBox>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <ui:Button Margin="8,0,0,0"
                           Command="{Binding Workspace.ToggleDualModeCommand}"
                           ToolTip="2분할 토글 (Ctrl+Shift+D)">
                    <ui:SymbolIcon Symbol="WindowMultiple20" />
                </ui:Button>
                <ui:Button Margin="4,0,0,0"
                           Command="{Binding Workspace.ComparePanesCommand}"
                           ToolTip="두 페인 비교 — 이쪽만(앰버)/최신(초록)/오래됨(파랑). 다시 누르면 갱신, 폴더 이동 시 해제">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ArrowSwap20" Margin="0,0,4,0" />
                        <TextBlock VerticalAlignment="Center" Text="비교" />
                    </StackPanel>
                </ui:Button>
                <ui:Button Margin="8,0,0,0"
                           Appearance="{Binding ViewMode, Converter={StaticResource EnumToAppearanceConverter}, ConverterParameter=Details}"
                           Command="{Binding SetViewModeCommand}"
                           CommandParameter="Details"
                           ToolTip="자세히 보기 (컬럼)">
                    <ui:SymbolIcon Symbol="Table24" />
                </ui:Button>
                <ui:Button Margin="2,0,0,0"
                           Appearance="{Binding ViewMode, Converter={StaticResource EnumToAppearanceConverter}, ConverterParameter=List}"
                           Command="{Binding SetViewModeCommand}"
                           CommandParameter="List"
                           ToolTip="간단히 보기 (아이콘+이름)">
                    <ui:SymbolIcon Symbol="List24" />
                </ui:Button>
                <ui:Button Margin="2,0,0,0"
                           Appearance="{Binding ViewMode, Converter={StaticResource EnumToAppearanceConverter}, ConverterParameter=Thumbnails}"
                           Command="{Binding SetViewModeCommand}"
                           CommandParameter="Thumbnails"
                           ToolTip="썸네일 보기 (미리보기)">
                    <ui:SymbolIcon Symbol="Grid24" />
                </ui:Button>
                <Menu Margin="2,0,0,0" VerticalAlignment="Center" Background="Transparent">
                    <MenuItem ToolTip="썸네일 크기">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="크기" />
                                <TextBlock Margin="2,0,0,0" Text="▾" />
                            </StackPanel>
                        </MenuItem.Header>
                        <MenuItem Command="{Binding SetThumbnailSizeCommand}" CommandParameter="64" Header="작게" />
                        <MenuItem Command="{Binding SetThumbnailSizeCommand}" CommandParameter="96" Header="보통" />
                        <MenuItem Command="{Binding SetThumbnailSizeCommand}" CommandParameter="144" Header="크게" />
                    </MenuItem>
                </Menu>
                <ui:Button Margin="4,0,0,0"
                           Command="{Binding ToggleThemeCommand}"
                           ToolTip="{Binding CurrentTheme}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="WeatherMoon24" Margin="0,0,4,0" />
                        <TextBlock VerticalAlignment="Center" Text="테마" />
                    </StackPanel>
                </ui:Button>
                <ui:Button Margin="4,0,0,0"
                           Click="OnSettingsClick"
                           ToolTip="환경설정">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Settings20" Margin="0,0,4,0" />
                        <TextBlock VerticalAlignment="Center" Text="설정" />
                    </StackPanel>
                </ui:Button>
            </StackPanel>
        </Grid>

        <!-- 빠른 실행 바: 자주 쓰는 프로그램 (클릭=실행, 드래그&드롭=추가, 우클릭=제거) -->
        <Border Grid.Row="2"
                Margin="8,0,8,4"
                Padding="6,3"
                AllowDrop="True"
                Background="Transparent"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                DragOver="OnLauncherDragOver"
                Drop="OnLauncherDrop"
                ToolTip="자주 쓰는 프로그램 — 클릭=실행, 실행 파일/바로가기를 끌어다 놓으면 추가, 우클릭=제거"
                Visibility="{Binding ProgramLauncher.IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Margin="2,0,8,0"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Opacity="0.5"
                           Text="빠른 실행" />
                <ItemsControl ItemsSource="{Binding ProgramLauncher.Items}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Margin="2,0"
                                    Padding="6,3"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding DataContext.ProgramLauncher.LaunchCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}"
                                    Cursor="Hand"
                                    Tag="{Binding DataContext.ProgramLauncher, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    ToolTip="{Binding DisplayName}">
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Command="{Binding PlacementTarget.Tag.RemoveCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding}"
                                                  Header="런처에서 제거" />
                                    </ContextMenu>
                                </Button.ContextMenu>
                                <StackPanel Orientation="Horizontal">
                                    <Image Width="16"
                                           Height="16"
                                           Margin="0,0,5,0"
                                           VerticalAlignment="Center"
                                           Source="{Binding Icon}" />
                                    <TextBlock VerticalAlignment="Center" Text="{Binding DisplayName}" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- 본문: 드라이브 사이드바 | 좌 페인 | (스플리터) | 우 페인 -->
        <Grid Grid.Row="3" Margin="8,0,8,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="120" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" MaxHeight="260" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Margin="4,0,0,4"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Opacity="0.6"
                           Text="즐겨찾기" />

                <ListBox x:Name="FavoritesList"
                         Grid.Row="1"
                         AllowDrop="True"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemsSource="{Binding Favorites.Items}"
                         DragOver="OnFavoritesDragOver"
                         Drop="OnFavoritesDrop"
                         ToolTip="파일/폴더를 끌어다 놓으면 즐겨찾기에 추가됩니다">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid x:Name="FavRow"
                                  Margin="0,1"
                                  Background="Transparent"
                                  MouseLeftButtonUp="OnFavoriteRowClick"
                                  Tag="{Binding DataContext.Favorites, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                  ToolTip="{Binding Path}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Command="{Binding PlacementTarget.Tag.MoveUpCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding}"
                                                  Header="위로 이동" />
                                        <MenuItem Command="{Binding PlacementTarget.Tag.MoveDownCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding}"
                                                  Header="아래로 이동" />
                                        <Separator />
                                        <MenuItem Command="{Binding PlacementTarget.Tag.RemoveCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding}"
                                                  Header="즐겨찾기에서 제거" />
                                    </ContextMenu>
                                </Grid.ContextMenu>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Margin="0,0,6,0" Text="{Binding Glyph}" />
                                    <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <StackPanel x:Name="FavButtons"
                                            Grid.Column="1"
                                            Orientation="Horizontal"
                                            Visibility="Collapsed">
                                    <Button Command="{Binding DataContext.Favorites.MoveUpCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}"
                                            Content="↑"
                                            Style="{StaticResource FavHoverButton}"
                                            ToolTip="위로 이동" />
                                    <Button Command="{Binding DataContext.Favorites.MoveDownCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}"
                                            Content="↓"
                                            Style="{StaticResource FavHoverButton}"
                                            ToolTip="아래로 이동" />
                                    <Button Command="{Binding DataContext.Favorites.RemoveCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}"
                                            Content="✕"
                                            Style="{StaticResource FavHoverButton}"
                                            ToolTip="제거" />
                                </StackPanel>
                            </Grid>
                            <DataTemplate.Triggers>
                                <Trigger SourceName="FavRow" Property="IsMouseOver" Value="True">
                                    <Setter TargetName="FavButtons" Property="Visibility" Value="Visible" />
                                </Trigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Grid.Row="2"
                           Margin="4,10,0,4"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Opacity="0.6"
                           Text="드라이브" />

                <ListBox x:Name="DriveList"
                         Grid.Row="3"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemsSource="{Binding DriveSidebar.Drives}"
                         SelectionChanged="OnDriveSelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,2" Orientation="Horizontal">
                                <TextBlock Margin="0,0,8,0"
                                           VerticalAlignment="Center"
                                           FontSize="18"
                                           Text="{Binding Glyph}" />
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                    <TextBlock FontSize="11"
                                               Opacity="0.6"
                                               Text="{Binding DetailText}" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          Background="Transparent" />

            <Grid x:Name="PanesGrid" Grid.Column="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="LeftPaneColumn" Width="*" />
                    <ColumnDefinition x:Name="PaneSplitterColumn" Width="0" />
                    <ColumnDefinition x:Name="RightPaneColumn" Width="0" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderThickness" Value="0,2,0,0" />
                            <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
                            <Setter Property="Opacity" Value="0.75" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Workspace.ActiveSide}" Value="Left">
                                    <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorSecondaryBrush}" />
                                    <Setter Property="BorderThickness" Value="0,3,0,0" />
                                    <Setter Property="Opacity" Value="1.0" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <views:PaneView x:Name="LeftPaneView" DataContext="{Binding Workspace.LeftPane}" />
                </Border>

                <GridSplitter x:Name="PaneSplitter"
                              Grid.Column="1"
                              HorizontalAlignment="Stretch"
                              Background="Transparent"
                              Visibility="Collapsed" />

                <Border Grid.Column="2">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderThickness" Value="0,2,0,0" />
                            <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
                            <Setter Property="Opacity" Value="0.75" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Workspace.ActiveSide}" Value="Right">
                                    <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorSecondaryBrush}" />
                                    <Setter Property="BorderThickness" Value="0,3,0,0" />
                                    <Setter Property="Opacity" Value="1.0" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <views:PaneView x:Name="RightPaneView"
                                    DataContext="{Binding Workspace.RightPane}"
                                    Visibility="Collapsed" />
                </Border>
            </Grid>
        </Grid>

        <!-- 작업 큐 패널 -->
        <Border Grid.Row="4"
                Margin="8,6,8,0"
                Padding="10,6"
                BorderThickness="1"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                CornerRadius="6"
                Visibility="{Binding OperationQueue.HasItems, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock FontSize="12" FontWeight="SemiBold" Opacity="0.7">
                        <Run Text="작업" /><Run Text=" (" /><Run Text="{Binding OperationQueue.ActiveCount, Mode=OneWay}" /><Run Text="개 진행 중)" />
                    </TextBlock>
                    <ui:Button Grid.Column="1"
                               Padding="6,0"
                               FontSize="11"
                               Command="{Binding OperationQueue.ClearFinishedCommand}"
                               Content="목록 정리" />
                </Grid>

                <ScrollViewer Grid.Row="1"
                              MaxHeight="150"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding OperationQueue.Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock FontSize="12"
                                                   Text="{Binding Description}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontSize="11"
                                                   Opacity="0.6"
                                                   Text="{Binding DetailText}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1"
                                                Margin="8,0"
                                                VerticalAlignment="Center">
                                        <ProgressBar Height="6"
                                                     IsIndeterminate="{Binding IsIndeterminate}"
                                                     Maximum="100"
                                                     Value="{Binding Percent, Mode=OneWay}" />
                                        <TextBlock FontSize="11"
                                                   HorizontalAlignment="Center"
                                                   Opacity="0.6"
                                                   Text="{Binding StateText}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal">
                                        <Button Padding="6,2"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Command="{Binding PauseCommand}"
                                                Content="⏸"
                                                ToolTip="일시정지"
                                                Visibility="{Binding CanPause, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <Button Padding="6,2"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Command="{Binding ResumeCommand}"
                                                Content="▶"
                                                ToolTip="재개"
                                                Visibility="{Binding CanResume, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <Button Padding="6,2"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Command="{Binding CancelCommand}"
                                                Content="✕"
                                                ToolTip="취소"
                                                Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- 단축키 기능 바 (Total Commander 스타일) — 클릭 가능, 활성 페인 대상 -->
        <UniformGrid Grid.Row="5"
                     Margin="8,4,8,0"
                     Rows="1">
            <Button Style="{StaticResource FnKeyButton}"
                    Command="{Binding Workspace.ActiveFileList.BeginRenameCommand}"
                    ToolTip="선택 항목 이름 변경">
                <TextBlock><Run FontWeight="Bold" Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" Text="F2" /><Run Text="  이름변경" /></TextBlock>
            </Button>
            <Button Style="{StaticResource FnKeyButton}"
                    Command="{Binding Workspace.CopyToOtherPaneCommand}"
                    ToolTip="반대 페인으로 복사">
                <TextBlock><Run FontWeight="Bold" Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" Text="F5" /><Run Text="  복사" /></TextBlock>
            </Button>
            <Button Style="{StaticResource FnKeyButton}"
                    Command="{Binding Workspace.MoveToOtherPaneCommand}"
                    ToolTip="반대 페인으로 이동">
                <TextBlock><Run FontWeight="Bold" Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" Text="F6" /><Run Text="  이동" /></TextBlock>
            </Button>
            <Button Style="{StaticResource FnKeyButton}"
                    Command="{Binding Workspace.ActiveFileList.CreateFolderCommand}"
                    ToolTip="새 폴더 만들기">
                <TextBlock><Run FontWeight="Bold" Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" Text="F7" /><Run Text="  새폴더" /></TextBlock>
            </Button>
            <Button Style="{StaticResource FnKeyButton}"
                    Command="{Binding Workspace.ActiveFileList.DeleteSelectionCommand}"
                    ToolTip="휴지통으로 삭제">
                <TextBlock><Run FontWeight="Bold" Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" Text="Del" /><Run Text="  삭제" /></TextBlock>
            </Button>
            <Button Style="{StaticResource FnKeyButton}"
                    Command="{Binding Workspace.ToggleQuickViewCommand}"
                    ToolTip="반대 페인 미리보기 토글">
                <TextBlock><Run FontWeight="Bold" Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" Text="Ctrl+Q" /><Run Text="  미리보기" /></TextBlock>
            </Button>
        </UniformGrid>

        <!-- 상태바 -->
        <Grid Grid.Row="6" Margin="12,4,12,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" FontSize="12" Opacity="0.7">
                <Run Text="{Binding Workspace.ActiveFileList.Items.Count, Mode=OneWay}" /><Run Text="개 항목" />
            </TextBlock>
            <TextBlock Grid.Column="1"
                       Margin="16,0,0,0"
                       FontSize="12"
                       Opacity="0.7"
                       Text="{Binding Workspace.ActiveFileList.StatusMessage}"
                       TextTrimming="CharacterEllipsis" />
            <!-- 인덱싱 현황: 스캔 중이면 스피너+드라이브, 완료면 총 항목 수. 툴팁에 드라이브별 상세. -->
            <StackPanel Grid.Column="2"
                        Margin="16,0,0,0"
                        Orientation="Horizontal"
                        ToolTip="{Binding IndexingStatus.Detail}"
                        Visibility="{Binding IndexingStatus.HasActivity, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ui:ProgressRing Width="12"
                                 Height="12"
                                 VerticalAlignment="Center"
                                 IsIndeterminate="True"
                                 Visibility="{Binding IndexingStatus.IsIndexing, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <TextBlock Margin="6,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Opacity="0.7"
                           Text="{Binding IndexingStatus.Summary}"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
            <TextBlock Grid.Column="3"
                       Margin="16,0,0,0"
                       FontSize="12"
                       Opacity="0.55"
                       Text="{x:Static app:AppInfo.Version}"
                       ToolTip="Folder Spot 버전" />
        </Grid>
    </Grid>
</ui:FluentWindow>
