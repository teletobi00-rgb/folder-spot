<ui:FluentWindow x:Class="Explorer.App.Views.SearchPopupWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:viewmodels="clr-namespace:Explorer.App.ViewModels"
                 mc:Ignorable="d"
                 d:DataContext="{d:DesignInstance Type=viewmodels:SearchPopupViewModel}"
                 Title="파일 검색"
                 FontFamily="{StaticResource AppFontFamily}"
                 Width="600"
                 SizeToContent="Height"
                 MaxHeight="520"
                 WindowStartupLocation="Manual"
                 ResizeMode="NoResize"
                 ShowInTaskbar="False"
                 Topmost="True"
                 WindowBackdropType="Acrylic"
                 ExtendsContentIntoTitleBar="True"
                 WindowCornerPreference="Round"
                 PreviewKeyDown="OnPreviewKeyDown"
                 Deactivated="OnDeactivated">
    <StackPanel Margin="14,12,14,12">
        <TextBox x:Name="SearchBox"
                 FontSize="17"
                 Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Margin="4,6,0,2"
                   FontSize="11"
                   Opacity="0.55"
                   Text="{Binding StatusText}" />

        <ListView x:Name="ResultsList"
                  MaxHeight="380"
                  Margin="0,4,0,0"
                  ItemsSource="{Binding Results}"
                  SelectedItem="{Binding Selected}"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  MouseDoubleClick="OnResultDoubleClick"
                  Visibility="{Binding Results.Count, Converter={StaticResource CountToVisibilityConverter}}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="2,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Image Width="20"
                               Height="20"
                               Margin="0,0,10,0"
                               VerticalAlignment="Center"
                               Source="{Binding Icon}" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock FontSize="14"
                                       Text="{Binding Name}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="11"
                                       Opacity="0.55"
                                       Text="{Binding DirectoryText}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <TextBlock Grid.Column="2"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Opacity="0.55"
                                   Text="{Binding DetailText}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock Margin="4,8,0,0"
                   FontSize="11"
                   Opacity="0.45"
                   Text="Enter 열기 · Ctrl+Enter 폴더에서 보기 · Esc 닫기" />
    </StackPanel>
</ui:FluentWindow>
