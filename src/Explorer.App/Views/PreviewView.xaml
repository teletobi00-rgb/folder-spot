<UserControl x:Class="Explorer.App.Views.PreviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="clr-namespace:Explorer.App.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewmodels:PreviewViewModel}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <Grid Grid.Row="0" Margin="8,6,8,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       Opacity="0.6"
                       Text="미리보기" />
            <TextBlock Grid.Column="1"
                       Margin="8,0,0,0"
                       VerticalAlignment="Center"
                       Text="{Binding DisplayName}"
                       TextTrimming="CharacterEllipsis" />
            <ui:ProgressRing Grid.Column="2"
                             Width="18"
                             Height="18"
                             IsIndeterminate="True"
                             Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </Grid>

        <!-- 본문: Kind별 표면 -->
        <Border Grid.Row="1"
                Margin="4,0,4,0"
                BorderThickness="1"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                CornerRadius="6">
            <Grid>
                <!-- None / 안내 -->
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Opacity="0.5"
                           Text="항목을 선택하면 미리보기가 표시됩니다"
                           Visibility="{Binding Kind, Converter={StaticResource PreviewKindToVisibilityConverter}, ConverterParameter=None}" />

                <!-- 이미지 -->
                <Image Margin="8"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       Source="{Binding ImageSource}"
                       Visibility="{Binding Kind, Converter={StaticResource PreviewKindToVisibilityConverter}, ConverterParameter=Image}" />

                <!-- 텍스트/코드 (AvalonEdit — 코드비하인드가 내용 갱신) -->
                <avalon:TextEditor x:Name="TextView"
                                   FontFamily="Cascadia Code, Consolas, D2Coding, monospace"
                                   FontSize="13"
                                   IsReadOnly="True"
                                   ShowLineNumbers="True"
                                   WordWrap="False"
                                   HorizontalScrollBarVisibility="Auto"
                                   VerticalScrollBarVisibility="Auto"
                                   Visibility="{Binding Kind, Converter={StaticResource PreviewKindToVisibilityConverter}, ConverterParameter=Text}" />

                <!-- 미디어 (코드비하인드가 Source 설정/정지) -->
                <Grid Visibility="{Binding Kind, Converter={StaticResource PreviewKindToVisibilityConverter}, ConverterParameter=Media}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <MediaElement x:Name="MediaView"
                                  Grid.Row="0"
                                  LoadedBehavior="Manual"
                                  ScrubbingEnabled="True"
                                  Stretch="Uniform"
                                  UnloadedBehavior="Stop" />
                    <StackPanel Grid.Row="1"
                                Margin="8"
                                HorizontalAlignment="Center"
                                Orientation="Horizontal">
                        <ui:Button Margin="0,0,6,0" Click="OnMediaPlay" Content="▶ 재생" />
                        <ui:Button Margin="0,0,6,0" Click="OnMediaPause" Content="⏸ 일시정지" />
                        <ui:Button Click="OnMediaStop" Content="⏹ 정지" />
                    </StackPanel>
                </Grid>

                <!-- 압축 목록 -->
                <ListView Margin="4"
                          ItemsSource="{Binding ArchiveEntries}"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          Visibility="{Binding Kind, Converter={StaticResource PreviewKindToVisibilityConverter}, ConverterParameter=Archive}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Width="380"
                                            DisplayMemberBinding="{Binding Path}"
                                            Header="경로" />
                            <GridViewColumn Width="100"
                                            DisplayMemberBinding="{Binding Size, Converter={StaticResource FileSizeConverter}}"
                                            Header="크기" />
                        </GridView>
                    </ListView.View>
                </ListView>

                <!-- 정보 -->
                <ItemsControl Margin="16"
                              VerticalAlignment="Center"
                              ItemsSource="{Binding InfoLines}"
                              Visibility="{Binding Kind, Converter={StaticResource PreviewKindToVisibilityConverter}, ConverterParameter=Info}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontWeight="SemiBold"
                                           Opacity="0.6"
                                           Text="{Binding Label}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Value}"
                                           TextWrapping="Wrap" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 네이티브(실제 OLE) 미리보기 — 코드비하인드가 PreviewHandlerHost(HwndHost)를 Child로 넣는다 -->
                <Border x:Name="NativeHost"
                        Visibility="{Binding Kind, Converter={StaticResource PreviewKindToVisibilityConverter}, ConverterParameter=Native}" />

                <!-- 오류 -->
                <TextBlock Margin="16"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SystemFillColorCautionBrush}"
                           Text="{Binding ErrorText}"
                           TextWrapping="Wrap"
                           Visibility="{Binding Kind, Converter={StaticResource PreviewKindToVisibilityConverter}, ConverterParameter=Error}" />
            </Grid>
        </Border>

        <!-- 푸터 -->
        <TextBlock Grid.Row="2"
                   Margin="8,4,8,6"
                   FontSize="11"
                   Opacity="0.5"
                   Text="{Binding FooterText}" />
    </Grid>
</UserControl>
