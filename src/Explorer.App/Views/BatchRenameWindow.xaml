<ui:FluentWindow x:Class="Explorer.App.Views.BatchRenameWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:viewmodels="clr-namespace:Explorer.App.ViewModels"
                 mc:Ignorable="d"
                 d:DataContext="{d:DesignInstance Type=viewmodels:BatchRenameViewModel}"
                 Title="일괄 이름 변경"
                 Width="640"
                 Height="600"
                 FontFamily="{StaticResource AppFontFamily}"
                 FontSize="13"
                 Icon="pack://application:,,,/Assets/app.ico"
                 WindowStartupLocation="CenterOwner"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="일괄 이름 변경" />

        <!-- 옵션 -->
        <Grid Grid.Row="1" Margin="16,8,16,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" Text="찾기" />
            <ui:TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,12,6" PlaceholderText="바꿀 텍스트"
                        Text="{Binding Find, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Grid.Row="0" Grid.Column="2" Margin="0,0,8,6" VerticalAlignment="Center" Text="바꾸기" />
            <ui:TextBox Grid.Row="0" Grid.Column="3" Margin="0,0,0,6" PlaceholderText="대체 텍스트"
                        Text="{Binding Replace, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,6" VerticalAlignment="Center" Text="접두사" />
            <ui:TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,12,6" PlaceholderText="이름 앞에 추가"
                        Text="{Binding Prefix, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Grid.Row="1" Grid.Column="2" Margin="0,0,8,6" VerticalAlignment="Center" Text="접미사" />
            <ui:TextBox Grid.Row="1" Grid.Column="3" Margin="0,0,0,6" PlaceholderText="확장자 앞에 추가"
                        Text="{Binding Suffix, UpdateSourceTrigger=PropertyChanged}" />

            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4" Margin="0,4,0,0" Orientation="Horizontal">
                <CheckBox VerticalAlignment="Center" Content="연번 추가" IsChecked="{Binding UseSequence}" />
                <TextBlock Margin="16,0,6,0" VerticalAlignment="Center" Text="시작" />
                <ui:TextBox Width="64" Text="{Binding StartNumber, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Margin="16,0,6,0" VerticalAlignment="Center" Text="자릿수" />
                <ui:TextBox Width="64" Text="{Binding Padding, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </Grid>

        <!-- 미리보기 -->
        <Border Grid.Row="2"
                Margin="16,8,16,0"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="1"
                CornerRadius="6">
            <ListView Background="Transparent"
                      BorderThickness="0"
                      ItemsSource="{Binding Previews}"
                      VirtualizingPanel.IsVirtualizing="True">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="280" DisplayMemberBinding="{Binding OldName}" Header="기존 이름" />
                        <GridViewColumn Width="300" Header="새 이름">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding NewName}" TextTrimming="CharacterEllipsis">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Changed}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <!-- 상태 + 버튼 -->
        <Grid Grid.Row="3" Margin="16,12,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center">
                <ProgressBar Height="6"
                             Margin="0,0,0,4"
                             Maximum="100"
                             Value="{Binding Progress}"
                             Visibility="{Binding IsApplying, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <TextBlock Opacity="0.7"
                           Text="{Binding StatusMessage}"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                <ui:Button MinWidth="80"
                           Margin="0,0,8,0"
                           Appearance="Primary"
                           Command="{Binding ApplyCommand}"
                           Content="적용" />
                <ui:Button MinWidth="80" Click="OnCloseClick" Content="닫기" />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
