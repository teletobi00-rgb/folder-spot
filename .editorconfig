root = true

[*]
charset = utf-8
indent_style = space
indent_size = 4
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{xml,csproj,props,targets,xaml,json,yml,yaml}]
indent_size = 2

[*.cs]
# 네임스페이스는 파일 범위로
csharp_style_namespace_declarations = file_scoped:warning
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = true:suggestion
csharp_prefer_braces = true:warning
dotnet_sort_system_directives_first = true
dotnet_style_readonly_field = true:warning

# CA1848(LoggerMessage 대리자)/CA1873(로깅 인수 평가 비용): 콜드 패스에는 과한 보일러플레이트.
# 인덱서 등 핫패스에서만 LoggerMessage + IsEnabled 가드를 선택 적용한다.
dotnet_diagnostic.CA1848.severity = none
dotnet_diagnostic.CA1873.severity = none

# CA1711(예약 접미사): OperationQueue는 실제 도메인 개념(파일 작업 큐)이라 이름이 정확하다.
dotnet_diagnostic.CA1711.severity = none

# 테스트 코드: Method_Scenario_Expectation 밑줄 네이밍은 xUnit 표준 관례,
# 예약 예외 타입(COMException 등) 생성은 매퍼 검증에 필요
[tests/**.cs]
dotnet_diagnostic.CA1707.severity = none
dotnet_diagnostic.CA2201.severity = none
