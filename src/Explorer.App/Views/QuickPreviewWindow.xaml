<ui:FluentWindow x:Class="Explorer.App.Views.QuickPreviewWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:views="clr-namespace:Explorer.App.Views"
                 xmlns:viewmodels="clr-namespace:Explorer.App.ViewModels"
                 mc:Ignorable="d"
                 d:DataContext="{d:DesignInstance Type=viewmodels:PreviewViewModel}"
                 Title="빠른 미리보기"
                 FontFamily="{StaticResource AppFontFamily}"
                 Width="900"
                 Height="640"
                 WindowStartupLocation="CenterScreen"
                 ShowInTaskbar="False"
                 Topmost="True"
                 WindowBackdropType="Acrylic"
                 ExtendsContentIntoTitleBar="True"
                 WindowCornerPreference="Round"
                 PreviewKeyDown="OnPreviewKeyDown"
                 Deactivated="OnDeactivated">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <ui:TitleBar Grid.Row="0" Title="빠른 미리보기 (Space/Esc 닫기)" />
        <views:PreviewView Grid.Row="1" Margin="4" />
    </Grid>
</ui:FluentWindow>
