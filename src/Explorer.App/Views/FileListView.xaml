<UserControl x:Class="Explorer.App.Views.FileListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="clr-namespace:Explorer.App.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewmodels:FileListViewModel}">
    <UserControl.Resources>
        <!-- 항목 우클릭 메뉴: 자체 명령만 사용 — 셸 확장 in-proc 호스팅은 일부 확장에서 힙 손상을 일으켜 옵트인으로 격리 -->
        <ContextMenu x:Key="ItemContextMenu">
            <MenuItem Command="{Binding OpenItemCommand}"
                      CommandParameter="{Binding SelectedItem}"
                      FontWeight="SemiBold"
                      Header="열기"
                      InputGestureText="Enter" />
            <Separator />
            <MenuItem Command="{Binding CopySelectionCommand}" Header="복사" InputGestureText="Ctrl+C" />
            <MenuItem Command="{Binding CutSelectionCommand}" Header="잘라내기" InputGestureText="Ctrl+X" />
            <MenuItem Command="{Binding PasteCommand}" Header="붙여넣기" InputGestureText="Ctrl+V" />
            <Separator />
            <MenuItem Command="{Binding DeleteSelectionCommand}" Header="삭제" InputGestureText="Del" />
            <MenuItem Command="{Binding BeginRenameCommand}" Header="이름 바꾸기" InputGestureText="F2" />
            <MenuItem Click="OnBatchRenameClick" Header="일괄 이름 변경…" InputGestureText="Ctrl+Shift+R" />
            <MenuItem Command="{Binding CalculateFolderSizeCommand}" Header="폴더 크기 계산" InputGestureText="Alt+Shift+S" />
            <MenuItem Command="{Binding AddSelectionToFavoritesCommand}" Header="즐겨찾기에 추가" />
            <Separator />
            <MenuItem Command="{Binding CompressSelectionCommand}" Header="압축 (ZIP)" />
            <MenuItem Command="{Binding ExtractSelectionCommand}" Header="압축 풀기" />
            <Separator />
            <MenuItem Click="OnShowNativeMenuClick" Header="Windows 메뉴 표시" />
            <MenuItem Click="OnShowPropertiesClick" Header="속성" />
        </ContextMenu>

        <!-- 간단히(List) 셀: 작은 아이콘 + 이름, 고정 폭으로 가로 줄바꿈 -->
        <DataTemplate x:Key="ListItemTemplate">
            <StackPanel Width="210"
                        Margin="2,1"
                        Orientation="Horizontal"
                        ToolTip="{Binding Name}">
                <!-- 비교 상태 세로 라인 -->
                <Border Width="4"
                        Height="14"
                        Margin="0,0,4,0"
                        VerticalAlignment="Center"
                        Background="{Binding CompareState, Converter={StaticResource CompareStateToBrushConverter}}"
                        CornerRadius="1.5"
                        Visibility="{Binding CompareState, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter='OnlyHere,Newer,Older'}" />
                <Image Width="16"
                       Height="16"
                       Margin="0,0,6,0"
                       VerticalAlignment="Center"
                       Source="{Binding Icon}" />
                <TextBlock VerticalAlignment="Center"
                           Foreground="{Binding Extension, Converter={StaticResource ExtensionColorConverter}}"
                           Text="{Binding Name}"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </DataTemplate>

        <!-- 썸네일 셀: 미리보기 이미지 + 이름. 크기는 페인의 ThumbnailSize -->
        <DataTemplate x:Key="ThumbnailItemTemplate">
            <Grid Width="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=ListView}}"
                  Margin="6"
                  ToolTip="{Binding Name}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                
                <Grid Grid.Row="0" Height="{Binding DataContext.ThumbnailSize, RelativeSource={RelativeSource AncestorType=ListView}}">
                    <Image RenderOptions.BitmapScalingMode="HighQuality"
                           Source="{Binding Thumbnail}"
                           Stretch="Uniform" />
                    <!-- 비교 상태 도트 배지 -->
                    <Border Width="8"
                            Height="8"
                            Margin="4"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Background="{Binding CompareState, Converter={StaticResource CompareStateToBrushConverter}}"
                            BorderBrush="White"
                            BorderThickness="1"
                            CornerRadius="4"
                            Visibility="{Binding CompareState, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter='OnlyHere,Newer,Older'}" />
                </Grid>
                
                <TextBlock Grid.Row="1"
                           Margin="0,4,0,0"
                           MaxHeight="32"
                           Foreground="{Binding Extension, Converter={StaticResource ExtensionColorConverter}}"
                           Text="{Binding Name}"
                           TextAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="Wrap" />
            </Grid>
        </DataTemplate>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 빠른 필터 (Ctrl+F로 포커스, Esc로 해제) -->
        <ui:TextBox x:Name="FilterBox"
                    Grid.Row="0"
                    Margin="0,0,0,4"
                    FontSize="12"
                    ClearButtonEnabled="True"
                    PlaceholderText="빠른 필터 (Ctrl+F) — 이름으로 거르기"
                    KeyDown="OnFilterBoxKeyDown"
                    Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" />

        <ListView x:Name="FileList"
                  Grid.Row="1"
                  AllowDrop="True"
                  FontSize="12"
                  Background="{DynamicResource ApplicationBackgroundBrush}"
                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                  BorderThickness="0"
                  Visibility="{Binding ViewMode, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Details}"
                  ItemsSource="{Binding Items}"
                  SelectedItem="{Binding SelectedItem}"
                  SelectionMode="Extended"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  GridViewColumnHeader.Click="OnColumnHeaderClick"
                  MouseDoubleClick="OnItemDoubleClick"
                  SelectionChanged="OnSelectionChanged"
                  PreviewKeyDown="OnFileListPreviewKeyDown"
                  PreviewMouseLeftButtonDown="OnPreviewMouseLeftButtonDown"
                  PreviewMouseMove="OnPreviewMouseMove"
                  PreviewMouseLeftButtonUp="OnPreviewMouseLeftButtonUp"
                  MouseRightButtonUp="OnMouseRightButtonUp"
                  ContextMenuOpening="OnContextMenuOpening"
                  DragOver="OnDragOver"
                  Drop="OnDrop"
                  DragLeave="OnDragLeave">
            <ListView.ItemContainerStyle>
                <!-- 밀도 ↑: WPF-UI 테마 템플릿은 그대로 두고(세터만 오버라이드) 행 패딩/최소높이만 줄인다.
                     BasedOn 없이 세터만 지정하면 미지정 속성(Template 등)은 테마 스타일에서 내려온다. -->
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="6,1" />
                    <Setter Property="MinHeight" Value="0" />
                    <Setter Property="Margin" Value="0" />
                    <!-- 확장자 색이 없는 항목(폴더·dll 등)이 상속받을 기본 글자색 — 다크/라이트 적응.
                         확장자 색이 있는 항목은 이름 TextBlock이 이 값을 덮어쓴다. -->
                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.Resources>
                <Style TargetType="GridViewColumnHeader">
                    <Setter Property="Padding" Value="8,3" />
                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                    <Setter Property="Background" Value="{DynamicResource ApplicationBackgroundBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
                </Style>
            </ListView.Resources>
            <ListView.InputBindings>
                <KeyBinding Key="Return"
                            Command="{Binding OpenItemCommand}"
                            CommandParameter="{Binding SelectedItem}" />
                <KeyBinding Key="Back" Command="{Binding GoUpCommand}" />
                <KeyBinding Modifiers="Ctrl" Key="C" Command="{Binding CopySelectionCommand}" />
                <KeyBinding Modifiers="Ctrl" Key="X" Command="{Binding CutSelectionCommand}" />
                <KeyBinding Modifiers="Ctrl" Key="V" Command="{Binding PasteCommand}" />
                <KeyBinding Key="Delete" Command="{Binding DeleteSelectionCommand}" />
                <KeyBinding Modifiers="Shift" Key="Delete" Command="{Binding DeleteSelectionPermanentCommand}" />
                <KeyBinding Key="F2" Command="{Binding BeginRenameCommand}" />
                <KeyBinding Key="F7" Command="{Binding CreateFolderCommand}" />
            </ListView.InputBindings>
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Command="{Binding PasteCommand}"
                              Header="붙여넣기"
                              InputGestureText="Ctrl+V" />
                    <MenuItem Command="{Binding CreateFolderCommand}"
                              Header="새 폴더"
                              InputGestureText="F7" />
                    <MenuItem Command="{Binding OpenTerminalHereCommand}" Header="여기서 터미널 열기" />
                    <Separator />
                    <MenuItem Command="{Binding RefreshCommand}"
                              Header="새로 고침"
                              InputGestureText="Ctrl+R" />
                </ContextMenu>
            </ListView.ContextMenu>
            <ListView.View>
                <GridView>
                    <GridViewColumn x:Name="NameColumn" Header="이름" Width="340">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Opacity="{Binding NameOpacity}" Orientation="Horizontal">
                                    <!-- 비교 상태 세로 라인 -->
                                    <Border Width="4"
                                            Height="14"
                                            Margin="0,0,6,0"
                                            VerticalAlignment="Center"
                                            Background="{Binding CompareState, Converter={StaticResource CompareStateToBrushConverter}}"
                                            CornerRadius="1.5"
                                            Visibility="{Binding CompareState, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter='OnlyHere,Newer,Older'}" />
                                    <Image Width="14"
                                           Height="14"
                                           Margin="0,0,6,0"
                                           VerticalAlignment="Center"
                                           Source="{Binding Icon}" />
                                    <TextBlock Margin="0,0,4,0"
                                               VerticalAlignment="Center"
                                               FontSize="11"
                                               Text="🔒"
                                               ToolTip="보호된 파일 (암호화/AIP/PDF)"
                                               Visibility="{Binding IsProtected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    <TextBlock VerticalAlignment="Center"
                                               Foreground="{Binding Extension, Converter={StaticResource ExtensionColorConverter}}"
                                               Text="{Binding Name}"
                                               TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding IsRenaming, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                    <TextBox MinWidth="160"
                                             VerticalAlignment="Center"
                                             KeyDown="OnRenameBoxKeyDown"
                                             Loaded="OnRenameBoxLoaded"
                                             LostFocus="OnRenameBoxLostFocus"
                                             Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                             Visibility="{Binding IsRenaming, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn x:Name="ExtensionColumn"
                                    Width="70"
                                    DisplayMemberBinding="{Binding Extension}"
                                    Header="확장자" />
                    <GridViewColumn x:Name="SizeColumn" Header="크기" Width="100">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock HorizontalAlignment="Right"
                                           Text="{Binding SizeText}"
                                           TextAlignment="Right" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn x:Name="DateModifiedColumn"
                                    Width="140"
                                    DisplayMemberBinding="{Binding DateModifiedText}"
                                    Header="수정한 날짜" />
                    <GridViewColumn x:Name="AttributesColumn"
                                    Width="70"
                                    DisplayMemberBinding="{Binding AttributesText}"
                                    Header="특성" />
                </GridView>
            </ListView.View>
        </ListView>

        <!-- 간단히/썸네일 보기 (WrapPanel). 자세히가 아닐 때 표시 -->
        <ListView x:Name="IconsList"
                  Grid.Row="1"
                  Background="{DynamicResource ApplicationBackgroundBrush}"
                  BorderThickness="0"
                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                  ItemsSource="{Binding Items}"
                  SelectedItem="{Binding SelectedItem}"
                  SelectionMode="Extended"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ContextMenu="{StaticResource ItemContextMenu}"
                  MouseDoubleClick="OnItemDoubleClick"
                  SelectionChanged="OnSelectionChanged"
                  PreviewMouseLeftButtonDown="OnPreviewMouseLeftButtonDown"
                  PreviewMouseMove="OnPreviewMouseMove"
                  PreviewMouseLeftButtonUp="OnPreviewMouseLeftButtonUp"
                  Visibility="{Binding ViewMode, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter='List,Thumbnails'}">
            <ListView.Style>
                <Style TargetType="ListView">
                    <Setter Property="ItemTemplate" Value="{StaticResource ListItemTemplate}" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ViewMode}" Value="Thumbnails">
                            <Setter Property="ItemTemplate" Value="{StaticResource ThumbnailItemTemplate}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListView.Style>
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="Padding" Value="2" />
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <!-- 드래그 영역 선택(마퀴) 사각형 — 마우스 이벤트는 통과시킨다 -->
        <Canvas x:Name="MarqueeLayer" Grid.Row="1" IsHitTestVisible="False">
            <Border x:Name="MarqueeBox"
                    Background="{DynamicResource SystemAccentColorSecondaryBrush}"
                    BorderBrush="{DynamicResource SystemAccentColorSecondaryBrush}"
                    BorderThickness="1"
                    CornerRadius="1"
                    Opacity="0.35"
                    Visibility="Collapsed" />
        </Canvas>

        <!-- 로딩 오버레이 -->
        <Grid Grid.Row="1"
              Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="{DynamicResource ApplicationBackgroundBrush}" Opacity="0.55" />
            <ui:ProgressRing IsIndeterminate="True"
                             Width="48"
                             Height="48"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
        </Grid>

        <!-- 빈 폴더/오류 상태 -->
        <TextBlock x:Name="StatusText"
                   Grid.Row="1"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="14"
                   Opacity="0.6"
                   Visibility="Collapsed" />
    </Grid>
</UserControl>
