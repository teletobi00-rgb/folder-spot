<ui:FluentWindow x:Class="Explorer.App.Views.SettingsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:viewmodels="clr-namespace:Explorer.App.ViewModels"
                 mc:Ignorable="d"
                 d:DataContext="{d:DesignInstance Type=viewmodels:SettingsViewModel}"
                 Title="환경설정"
                 Icon="pack://application:,,,/Assets/app.ico"
                 Width="560"
                 Height="640"
                 FontFamily="{StaticResource AppFontFamily}"
                 FontSize="13"
                 WindowStartupLocation="CenterOwner"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="환경설정" />

        <ScrollViewer Grid.Row="1" Margin="16,4,16,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 일반 -->
                <TextBlock Margin="0,0,0,8"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Text="일반" />

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="테마" />
                    <ComboBox Grid.Column="1"
                              MinWidth="160"
                              HorizontalAlignment="Left"
                              ItemsSource="{Binding Themes}"
                              SelectedItem="{Binding SelectedTheme}" />
                </Grid>

                <CheckBox Margin="0,4,0,0"
                          Content="빠른 인덱싱 (NTFS·관리자 — 다음 시작부터 적용)"
                          IsChecked="{Binding UseFastIndexing}" />
                <CheckBox Margin="0,4,0,0"
                          Content="네트워크 드라이브 인덱싱 (느림·재귀 스캔 — 다음 시작부터 적용)"
                          IsChecked="{Binding IndexNetworkDrives}" />
                <CheckBox Margin="0,4,0,0"
                          Content="Windows 시작 시 자동 실행 (부팅 후 인덱싱 시작)"
                          IsChecked="{Binding AutoStartOnBoot}" />
                <CheckBox Margin="0,4,0,0"
                          Content="상단 빠른 실행 바 표시 (자주 쓰는 프로그램)"
                          IsChecked="{Binding ShowProgramLauncher}" />

                <Separator Margin="0,16" />

                <!-- 확장자별 글자색 -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock FontSize="15" FontWeight="SemiBold" Text="확장자별 파일명 색상" />
                        <TextBlock Margin="0,2,0,0"
                                   FontSize="11"
                                   Opacity="0.6"
                                   Text="파일 목록에서 확장자에 따라 이름 글자색이 바뀝니다." />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <ui:Button Margin="0,0,4,0" Command="{Binding AddRowCommand}" Content="추가" />
                        <ui:Button Command="{Binding ResetColorsCommand}" Content="기본값 복원" />
                    </StackPanel>
                </Grid>

                <ItemsControl ItemsSource="{Binding ColorRows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ui:TextBox Grid.Column="0"
                                            Margin="0,0,6,0"
                                            PlaceholderText="확장자"
                                            Text="{Binding Extension, UpdateSourceTrigger=PropertyChanged}" />
                                <ui:TextBox Grid.Column="1"
                                            Margin="0,0,6,0"
                                            PlaceholderText="#RRGGBB"
                                            Text="{Binding Hex, UpdateSourceTrigger=PropertyChanged}" />
                                <Border Grid.Column="2"
                                        Width="20"
                                        Height="20"
                                        VerticalAlignment="Center"
                                        Background="{Binding Hex, Converter={StaticResource HexToBrushConverter}}"
                                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="3" />
                                <TextBlock Grid.Column="3"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{Binding Hex, Converter={StaticResource HexToBrushConverter}}"
                                           Text="가나다 Sample.ext"
                                           TextTrimming="CharacterEllipsis" />
                                <Button Grid.Column="4"
                                        Padding="6,2"
                                        VerticalAlignment="Center"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Command="{Binding DataContext.RemoveRowCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Content="✕"
                                        FontSize="11"
                                        ToolTip="이 항목 삭제" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- 저장/취소 -->
        <StackPanel Grid.Row="2"
                    Margin="16,12,16,16"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <ui:Button MinWidth="80"
                       Margin="0,0,8,0"
                       Appearance="Primary"
                       Click="OnSaveClick"
                       Content="저장" />
            <ui:Button MinWidth="80"
                       Click="OnCancelClick"
                       Content="취소" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
