<ui:FluentWindow x:Class="Explorer.App.Views.ConflictDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="이름 충돌"
                 Width="460"
                 SizeToContent="Height"
                 ResizeMode="NoResize"
                 WindowStartupLocation="CenterOwner"
                 ShowInTaskbar="False"
                 WindowBackdropType="Mica">
    <StackPanel Margin="20,12,20,16">
        <TextBlock FontSize="16" FontWeight="SemiBold" Text="같은 이름의 항목이 이미 있습니다" />
        <TextBlock x:Name="NameText"
                   Margin="0,8,0,2"
                   FontWeight="SemiBold"
                   TextTrimming="CharacterEllipsis" />
        <TextBlock x:Name="RemainingText"
                   Margin="0,0,0,10"
                   FontSize="12"
                   Opacity="0.6" />

        <Border Padding="10,8"
                BorderThickness="1"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,12,2" FontWeight="SemiBold" Text="원본" />
                <TextBlock x:Name="SourceText" Grid.Row="0" Grid.Column="1" Opacity="0.8" />
                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,12,0" FontWeight="SemiBold" Text="대상" />
                <TextBlock x:Name="TargetText" Grid.Row="1" Grid.Column="1" Opacity="0.8" />
            </Grid>
        </Border>

        <CheckBox x:Name="ApplyToAllCheck"
                  Margin="0,12,0,12"
                  Content="나머지 충돌에도 모두 적용" />

        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
            <ui:Button Margin="0,0,8,0"
                       Appearance="Primary"
                       Click="OnOverwrite"
                       Content="덮어쓰기" />
            <ui:Button Margin="0,0,8,0" Click="OnKeepBoth" Content="둘 다 유지" />
            <ui:Button Margin="0,0,8,0" Click="OnSkip" Content="건너뛰기" />
            <ui:Button Click="OnCancel" Content="취소" />
        </StackPanel>
    </StackPanel>
</ui:FluentWindow>
