<UserControl x:Class="Explorer.App.Views.FileListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="clr-namespace:Explorer.App.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewmodels:FileListViewModel}">
    <UserControl.Resources>
        <!-- 항목 우클릭 메뉴: 자체 명령만 사용 — 셸 확장 in-proc 호스팅은 일부 확장에서 힙 손상을 일으켜 옵트인으로 격리 -->
        <ContextMenu x:Key="ItemContextMenu">
            <MenuItem Command="{Binding OpenItemCommand}"
                      CommandParameter="{Binding SelectedItem}"
                      FontWeight="SemiBold"
                      Header="열기"
                      InputGestureText="Enter" />
            <Separator />
            <MenuItem Command="{Binding CopySelectionCommand}" Header="복사" InputGestureText="Ctrl+C" />
            <MenuItem Command="{Binding CutSelectionCommand}" Header="잘라내기" InputGestureText="Ctrl+X" />
            <MenuItem Command="{Binding PasteCommand}" Header="붙여넣기" InputGestureText="Ctrl+V" />
            <Separator />
            <MenuItem Command="{Binding DeleteSelectionCommand}" Header="삭제" InputGestureText="Del" />
            <MenuItem Command="{Binding BeginRenameCommand}" Header="이름 바꾸기" InputGestureText="F2" />
            <MenuItem Command="{Binding AddSelectionToFavoritesCommand}" Header="즐겨찾기에 추가" />
            <Separator />
            <MenuItem Click="OnShowNativeMenuClick" Header="Windows 메뉴 표시 (불안정 ⚠)" />
            <MenuItem Click="OnShowPropertiesClick" Header="속성" />
        </ContextMenu>
    </UserControl.Resources>
    <Grid>
        <ListView x:Name="FileList"
                  AllowDrop="True"
                  FontSize="12"
                  ItemsSource="{Binding Items}"
                  SelectedItem="{Binding SelectedItem}"
                  SelectionMode="Extended"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  GridViewColumnHeader.Click="OnColumnHeaderClick"
                  MouseDoubleClick="OnItemDoubleClick"
                  SelectionChanged="OnSelectionChanged"
                  PreviewKeyDown="OnFileListPreviewKeyDown"
                  PreviewMouseLeftButtonDown="OnPreviewMouseLeftButtonDown"
                  PreviewMouseMove="OnPreviewMouseMove"
                  MouseRightButtonUp="OnMouseRightButtonUp"
                  ContextMenuOpening="OnContextMenuOpening"
                  DragOver="OnDragOver"
                  Drop="OnDrop"
                  DragLeave="OnDragLeave">
            <ListView.ItemContainerStyle>
                <!-- 밀도 ↑: WPF-UI 테마 템플릿은 그대로 두고(세터만 오버라이드) 행 패딩/최소높이만 줄인다.
                     BasedOn 없이 세터만 지정하면 미지정 속성(Template 등)은 테마 스타일에서 내려온다. -->
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="6,1" />
                    <Setter Property="MinHeight" Value="0" />
                    <Setter Property="Margin" Value="0" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.Resources>
                <Style TargetType="GridViewColumnHeader">
                    <Setter Property="Padding" Value="8,3" />
                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                </Style>
            </ListView.Resources>
            <ListView.InputBindings>
                <KeyBinding Key="Return"
                            Command="{Binding OpenItemCommand}"
                            CommandParameter="{Binding SelectedItem}" />
                <KeyBinding Key="Back" Command="{Binding GoUpCommand}" />
                <KeyBinding Modifiers="Ctrl" Key="C" Command="{Binding CopySelectionCommand}" />
                <KeyBinding Modifiers="Ctrl" Key="X" Command="{Binding CutSelectionCommand}" />
                <KeyBinding Modifiers="Ctrl" Key="V" Command="{Binding PasteCommand}" />
                <KeyBinding Key="Delete" Command="{Binding DeleteSelectionCommand}" />
                <KeyBinding Modifiers="Shift" Key="Delete" Command="{Binding DeleteSelectionPermanentCommand}" />
                <KeyBinding Key="F2" Command="{Binding BeginRenameCommand}" />
                <KeyBinding Key="F7" Command="{Binding CreateFolderCommand}" />
            </ListView.InputBindings>
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Command="{Binding PasteCommand}"
                              Header="붙여넣기"
                              InputGestureText="Ctrl+V" />
                    <MenuItem Command="{Binding CreateFolderCommand}"
                              Header="새 폴더"
                              InputGestureText="F7" />
                    <Separator />
                    <MenuItem Command="{Binding RefreshCommand}"
                              Header="새로 고침"
                              InputGestureText="Ctrl+R" />
                </ContextMenu>
            </ListView.ContextMenu>
            <ListView.View>
                <GridView>
                    <GridViewColumn x:Name="NameColumn" Header="이름" Width="340">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Opacity="{Binding NameOpacity}" Orientation="Horizontal">
                                    <Image Width="14"
                                           Height="14"
                                           Margin="0,0,6,0"
                                           VerticalAlignment="Center"
                                           Source="{Binding Icon}" />
                                    <TextBlock VerticalAlignment="Center"
                                               Foreground="{Binding Extension, Converter={StaticResource ExtensionColorConverter}}"
                                               Text="{Binding Name}"
                                               TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding IsRenaming, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                    <TextBox MinWidth="160"
                                             VerticalAlignment="Center"
                                             KeyDown="OnRenameBoxKeyDown"
                                             Loaded="OnRenameBoxLoaded"
                                             LostFocus="OnRenameBoxLostFocus"
                                             Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                             Visibility="{Binding IsRenaming, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn x:Name="ExtensionColumn"
                                    Width="70"
                                    DisplayMemberBinding="{Binding Extension}"
                                    Header="확장자" />
                    <GridViewColumn x:Name="SizeColumn" Header="크기" Width="100">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock HorizontalAlignment="Right"
                                           Text="{Binding SizeText}"
                                           TextAlignment="Right" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn x:Name="DateModifiedColumn"
                                    Width="140"
                                    DisplayMemberBinding="{Binding DateModifiedText}"
                                    Header="수정한 날짜" />
                    <GridViewColumn x:Name="AttributesColumn"
                                    Width="70"
                                    DisplayMemberBinding="{Binding AttributesText}"
                                    Header="특성" />
                </GridView>
            </ListView.View>
        </ListView>

        <!-- 로딩 오버레이 -->
        <Border Background="Transparent"
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ui:ProgressRing IsIndeterminate="True"
                             Width="48"
                             Height="48"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
        </Border>

        <!-- 빈 폴더/오류 상태 -->
        <TextBlock x:Name="StatusText"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="14"
                   Opacity="0.6"
                   Visibility="Collapsed" />
    </Grid>
</UserControl>
